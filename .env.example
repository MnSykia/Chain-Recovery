# ChainRecovery Hackathon Configuration Template

# Web3 Provider Configurations
# Setup the RPC provider URL (Infura / Alchemy / Local Hardhat Node)
NEXT_PUBLIC_RPC_URL=https://sepolia.infura.io/v3/your-api-key

# Solidity Smart Contract Address (Deploy on testnets/mainnets)
NEXT_PUBLIC_CONTRACT_ADDRESS=0x7a2d3490cca0800a52d8291a139bc733621984f9b

# Wallet Fallback Configuration (True by default for easy hackathon judging)
NEXT_PUBLIC_FALLBACK_MOCK_PROVIDER=true

# Application Environment Toggles
NEXT_PUBLIC_APP_ENV=development
